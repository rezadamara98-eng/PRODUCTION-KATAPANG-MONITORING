# Email service account dari Google Cloud (ex: nama@project-id.iam.gserviceaccount.com)
GOOGLE_CLIENT_EMAIL=

# Private key dari file JSON service account (biarkan tanda \n apa adanya, jangan diubah jadi baris baru)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nISI_KEY_DISINI\n-----END PRIVATE KEY-----\n"

# ID spreadsheet, diambil dari URL:
# https://docs.google.com/spreadsheets/d/INI_ADALAH_SHEET_ID/edit
GOOGLE_SHEET_ID=

# Nama sheet + range kolom, default Sheet1 kolom A-E (Tanggal, Lini/Mesin, Output, Target, Reject)
GOOGLE_SHEET_RANGE=Sheet1!A:E
