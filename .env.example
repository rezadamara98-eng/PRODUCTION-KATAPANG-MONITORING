# === Google Sheets ===
# Email service account dari Google Cloud (ex: nama@project-id.iam.gserviceaccount.com)
GOOGLE_CLIENT_EMAIL=

# Private key dari file JSON service account (biarkan tanda \n apa adanya)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nISI_KEY_DISINI\n-----END PRIVATE KEY-----\n"

# ID spreadsheet, diambil dari URL:
# https://docs.google.com/spreadsheets/d/INI_ADALAH_SHEET_ID/edit
GOOGLE_SHEET_ID=

# Nama-nama tab yang mau digabung untuk data produksi, dipisah koma
GOOGLE_SHEET_TABS=STRONG PONT LINE,PA

# === Looker Studio ===
# Link embed laporan (ganti /reporting/ jadi /embed/reporting/ dari link biasa)
NEXT_PUBLIC_LOOKER_EMBED_URL=https://datastudio.google.com/embed/reporting/7d5af73c-9909-4c89-b8a0-58a91820257e/page/p_pcjxcdpc1d

# === Claude API (ASIK Solution) ===
ANTHROPIC_API_KEY=
